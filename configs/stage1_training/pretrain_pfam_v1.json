{
  "description": "Stage 1 PenCL pretraining with SwissProt + Pfam (pfam dataset mode, production-like).",
  "model_name": "BioM3-PenCL-pfam-v0",
  "tags": ["stage1", "pretrain_pfam"],
  "notes": [],
  "_base_configs": ["./models/_base_PenCL_train.json"],
  "_overwrite_configs": [],

  "data_path": "./data/swissprot_augmented.csv",
  "pfam_data_path": "./data/pfam_enriched_v2.csv",
  "dataset_type": "pfam",
  "model_type": "pfam",

  "wandb": false,
  "wandb_entity": "thenaturalmachine",
  "wandb_project": "BioM3-dev",
  "wandb_tags": ["pretrain_stage1", "pfam"],

  "choose_optim": "AdamW",
  "head_lr": 1e-3,
  "protein_encoder_lr": 1e-4,
  "text_encoder_lr": 1e-6,
  "weight_decay": 1e-6,
  "scale_learning_rate": false,

  "seed": 42,
  "epochs": 20,
  "valid_size": 0.1,
  "resume_from_checkpoint": null,
  "pretrained_weights": null,
  "batch_size": 8,
  "acc_grad_batches": 1,

  "device": "cuda",
  "precision": "32",
  "gpu_devices": 1,
  "num_nodes": 1,
  "num_workers": 0,

  "val_check_interval": 1.0,
  "limit_val_batches": 1.0,
  "log_every_n_steps": 10,

  "output_root": "./outputs/Stage1/pretraining",
  "checkpoints_folder": "checkpoints",
  "runs_folder": "runs",

  "save_metrics_history": true,
  "save_benchmark": true,

  "early_stopping_metric": null
}
