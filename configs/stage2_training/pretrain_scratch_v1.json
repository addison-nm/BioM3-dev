{
  "description": "Stage 2 Facilitator training from Stage 1 embeddings.",
  "model_name": "BioM3-Facilitator-v0",
  "tags": ["stage2", "pretrain_from_scratch"],
  "notes": [],
  "_base_configs": ["./models/_base_Facilitator_train.json"],
  "_overwrite_configs": [],

  "swissprot_data_path": "./outputs/Stage1/pretraining/runs/.../artifacts/pencl_embeddings_swissprot.pt",
  "pfam_data_path": "None",
  "output_swissprot_dict_path": "./outputs/Stage2/pretraining/stage2_swissprot.pt",
  "output_pfam_dict_path": "./outputs/Stage2/pretraining/stage2_pfam.pt",

  "wandb": false,
  "wandb_entity": "thenaturalmachine",
  "wandb_project": "BioM3-dev",
  "wandb_tags": ["pretrain_stage2"],

  "lr": 1e-3,
  "weight_decay": 1e-6,
  "scale_learning_rate": false,

  "seed": 42,
  "epochs": 20,
  "valid_size": 0.2,
  "resume_from_checkpoint": null,
  "pretrained_weights": null,
  "batch_size": 32,
  "acc_grad_batches": 1,

  "device": "cuda",
  "precision": "32",
  "gpu_devices": 1,
  "num_gpus": 1,
  "num_nodes": 1,
  "num_workers": 0,

  "val_check_interval": 1.0,
  "limit_val_batches": 1.0,
  "log_every_n_steps": 10,

  "output_root": "./outputs/Stage2/pretraining",
  "checkpoints_folder": "checkpoints",
  "runs_folder": "runs",

  "save_metrics_history": true,

  "early_stopping_metric": null
}
